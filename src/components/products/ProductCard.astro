---
interface Product {
  id: string;
  name: string;
  price: number;
  description: string;
  imagePath: string;
  category: string;
}

interface Props {
  product: Product;
  loading?: "lazy" | "eager";
}

import { SITE_CONFIG } from "../../config/site";

const { product, loading = "lazy" } = Astro.props;

const imageUrl = `${SITE_CONFIG.r2BaseUrl}/${product.imagePath}`;
---

<article class="product-card group">
  <div class="image-container">
    <img 
      src={imageUrl} 
      alt={product.name}
      loading={loading}
      decoding="async"
      class="product-image"
    />
    <div class="category-badge">{product.category}</div>
  </div>
  
  <div class="product-info">
    <div class="header">
      <h3 class="product-name">{product.name}</h3>
      <span class="product-price">${product.price.toFixed(2)}</span>
    </div>
    <p class="product-description">{product.description}</p>
    
    <button class="cta-button">
      <span>Ver detalles</span>
      <span class="material-symbols-outlined">arrow_forward</span>
    </button>
  </div>
</article>

<style>
  .product-card {
    background: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    border-color: var(--color-primary-container);
  }

  .image-container {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-surface-container);
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .category-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-family: var(--font-label-md);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-outline-variant);
  }

  .product-info {
    padding: var(--spacing-j-md);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: var(--spacing-j-xs);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .product-name {
    font-family: var(--font-headline-sm);
    font-size: 20px;
    color: var(--color-on-surface);
    margin: 0;
    line-height: 1.2;
  }

  .product-price {
    font-family: var(--font-headline-sm);
    font-size: 18px;
    color: var(--color-primary);
    font-weight: 700;
  }

  .product-description {
    font-family: var(--font-body-md);
    font-size: 14px;
    color: var(--color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }

  .cta-button {
    margin-top: var(--spacing-j-md);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    background: transparent;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    border-radius: var(--radius-lg);
    font-family: var(--font-label-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: var(--color-primary);
    color: white;
  }

  .cta-button .material-symbols-outlined {
    font-size: 18px;
    transition: transform 0.3s ease;
  }

  .cta-button:hover .material-symbols-outlined {
    transform: translateX(4px);
  }
</style>
