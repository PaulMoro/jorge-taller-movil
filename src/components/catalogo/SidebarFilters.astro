---
/**
 * Resumen: Barra lateral de filtros para el catálogo.
 * Contenido: Categorías, Marcas y sello de Garantía Oficial.
 * Interacción: Sticky top-32, hover effects en labels.
 */
---
<aside class="w-full lg:w-64 flex-shrink-0">
  <div class="sticky top-32 space-y-8">
    <div>
      <h3 class="font-label-md text-label-md uppercase mb-4 text-on-surface">Categorías</h3>
      <div class="space-y-3">
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="w-4 h-4 border border-outline group-hover:border-primary transition-colors"></div>
          <span class="text-body-md font-body-md text-on-surface-variant group-hover:text-primary">Máquinas de Corte</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="w-4 h-4 border border-outline group-hover:border-primary transition-colors"></div>
          <span class="text-body-md font-body-md text-on-surface-variant group-hover:text-primary">Trimmers</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="w-4 h-4 border border-primary bg-primary"></div>
          <span class="text-body-md font-body-md text-on-surface font-semibold">Herramientas Térmicas</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="w-4 h-4 border border-outline group-hover:border-primary transition-colors"></div>
          <span class="text-body-md font-body-md text-on-surface-variant group-hover:text-primary">Secadores Industriales</span>
        </label>
      </div>
    </div>
    <div class="pt-8 border-t border-outline-variant">
      <h3 class="font-label-md text-label-md uppercase mb-4 text-on-surface">Marca</h3>
      <div class="space-y-3">
        <label class="flex items-center gap-3 cursor-pointer">
          <div class="w-4 h-4 border border-outline"></div>
          <span class="text-body-md font-body-md text-on-surface-variant">Stronge Machine</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <div class="w-4 h-4 border border-outline"></div>
          <span class="text-body-md font-body-md text-on-surface-variant">BaByliss PRO</span>
        </label>
      </div>
    </div>
    <div class="bg-surface-container-low p-6 border border-outline-variant">
      <span class="material-symbols-outlined text-primary mb-3">verified</span>
      <h4 class="font-label-md text-label-md uppercase mb-2">Garantía Oficial</h4>
      <p class="text-xs text-on-surface-variant leading-relaxed">Todos nuestros equipos incluyen soporte técnico certificado y garantía directa de fábrica.</p>
    </div>
  </div>
</aside>
