/**
 * Resumen: Banner publicitario dentro de la grilla de productos.
 * Contenido: Imagen de fondo cinemática, texto promocional y botón de acción.
 * Interacción: Botón con efectos hover.
 */
---
<div class="col-span-1 md:col-span-2 relative aspect-[2.47] border border-outline-variant overflow-hidden">
  <img 
    class="w-full h-full object-cover"
    src="https://lh3.googleusercontent.com/aida/ADBb0ug26pimlYuVWW2uo-YQjPrhV5BqDljrMXNK7Zrv08gVvLuFGiHmbuyzw1VpnVs-M9l1j8rbHLOeMMC6thsFSmOWTzAVfwq_2qg5Dn87qIRhMGTFw8XUA6h47fyiYPvjlP5-WgTtTgO0MkzaQBe2S3Ex62B7niad1eOkffxMwbb85SnQfG3pmxo3WY5S3W4YqaNwKDHYqdzFk4kW_vf8sXMy8LX4rZHctnket40zUP2RAnACU5oP3UNIRC0eRydTXeWg1yJmYNbta10" 
    alt="Estación de trabajo de barbero profesional"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-transparent flex flex-col justify-center px-12 text-white">
    <span class="font-label-md text-label-md uppercase tracking-[0.2em] mb-4">Servicio Técnico Especializado</span>
    <h3 class="font-headline-md text-headline-md mb-6 max-w-md">Mantenimiento de Precisión para su Equipo</h3>
    <div>
      <button class="bg-white text-primary px-8 py-4 font-label-md text-label-md uppercase hover:bg-primary hover:text-white transition-all">
        Solicitar Mantenimiento
      </button>
    </div>
  </div>
</div>
