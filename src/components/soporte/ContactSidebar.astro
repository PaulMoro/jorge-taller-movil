---
/**
 * Resumen: Barra lateral con información de contacto y disponibilidad.
 * Contenido: Disponibilidad en tiempo real, horarios de atención, ubicación con mapa y redes sociales.
 * Interacción: Enlaces con efectos hover y transición de escala en imágenes.
 */
import { SOCIAL_LINKS, SITE_CONFIG } from '../../config/site';
---
<aside class="lg:col-span-4 space-y-lg">
  <!-- Status & Availability -->
  <div class="bg-white border border-outline-variant p-lg rounded">
    <h3 class="font-headline-sm text-headline-sm text-on-surface mb-md">Real-time Availability</h3>
    <div class="space-y-md">
      <div class="flex items-center justify-between border-b border-surface-container-highest pb-sm">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">engineering</span>
          <span class="text-body-md font-medium">Technicians Online</span>
        </div>
        <span class="text-label-md font-label-md px-2 py-1 bg-green-100 text-green-800 rounded">6 ACTIVE</span>
      </div>
      <div class="flex items-center justify-between border-b border-surface-container-highest pb-sm">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">schedule</span>
          <span class="text-body-md font-medium">Wait Time</span>
        </div>
        <span class="text-body-md text-on-surface-variant">~45 mins</span>
      </div>
      <div class="flex items-center justify-between border-b border-surface-container-highest pb-sm">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">event_available</span>
          <span class="text-body-md font-medium">Next Slot</span>
        </div>
        <span class="text-body-md text-on-surface-variant">Today, 2:30 PM</span>
      </div>
    </div>
  </div>

  <!-- Business Hours Card -->
  <div class="bg-tertiary-fixed text-on-tertiary-fixed p-lg border border-outline-variant rounded">
    <h3 class="font-headline-sm text-headline-sm mb-md">Business Hours</h3>
    <ul class="space-y-sm text-body-md">
      <li class="flex justify-between"><span>Monday - Friday</span> <span>08:00 - 18:00</span></li>
      <li class="flex justify-between"><span>Saturday</span> <span>09:00 - 14:00</span></li>
      <li class="flex justify-between font-bold text-primary"><span>Sunday</span> <span>CLOSED</span></li>
    </ul>
  </div>

  <!-- Location Canvas -->
  <div class="bg-surface-container-highest border border-outline-variant overflow-hidden rounded">
    <div class="h-48 bg-slate-200 relative group">
      <img alt="Location Map"
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
        src="https://lh3.googleusercontent.com/aida/ADBb0ug26pimlYuVWW2uo-YQjPrhV5BqDljrMXNK7Zrv08gVvLuFGiHmbuyzw1VpnVs-M9l1j8rbHLOeMMC6thsFSmOWTzAVfwq_2qg5Dn87qIRhMGTFw8XUA6h47fyiYPvjlP5-WgTtTgO0MkzaQBe2S3Ex62B7niad1eOkffxMwbb85SnQfG3pmxo3WY5S3W4YqaNwKDHYqdzFk4kW_vf8sXMy8LX4rZHctnket40zUP2RAnACU5oP3UNIRC0eRydTXeWg1yJmYNbta10" />
      <div class="absolute inset-0 bg-primary/10 flex items-center justify-center pointer-events-none">
        <span class="material-symbols-outlined text-white text-5xl drop-shadow-lg" style="font-variation-settings: 'FILL' 1;">location_on</span>
      </div>
    </div>
    <div class="p-md bg-white">
      <p class="font-label-md text-label-md text-on-surface uppercase mb-1">HQ Address</p>
      <p class="text-body-md text-on-surface-variant">{SITE_CONFIG.address}</p>
      <div class="mt-md flex gap-4">
        <a class="text-primary flex items-center gap-2 hover:underline font-label-md text-label-md" href="#">
          <span class="material-symbols-outlined text-sm">directions</span> GET DIRECTIONS
        </a>
      </div>
    </div>
  </div>

  <!-- Social & Contact -->
  <div class="flex justify-between items-center p-md border border-outline-variant rounded bg-white">
    <div class="flex gap-4">
      <a class="material-symbols-outlined text-on-surface hover:text-primary transition-colors" href={`tel:${SITE_CONFIG.phone}`}>phone_in_talk</a>
      <a class="material-symbols-outlined text-on-surface hover:text-primary transition-colors" href={`mailto:${SITE_CONFIG.email}`}>mail</a>
    </div>
    <div class="flex gap-4">
      <a class="text-on-surface hover:text-primary transition-all font-bold tracking-tighter text-xs" target="_blank" href={SOCIAL_LINKS.instagram}>INSTAGRAM</a>
      <a class="text-on-surface hover:text-primary transition-all font-bold tracking-tighter text-xs" target="_blank" href={SOCIAL_LINKS.linkedin}>LINKEDIN</a>
    </div>
  </div>
</aside>
