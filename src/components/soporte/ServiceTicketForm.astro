---
/**
 * Resumen: Formulario de registro para tickets de servicio técnico.
 * Contenido: Campos para nombre, teléfono, modelo de equipo, tipo de servicio y descripción del problema.
 * Interacción: Inputs y selects con estilos personalizados de Tailwind, botón de envío con hover y escala.
 */
---
<div class="lg:col-span-8 bg-surface-container-lowest border border-outline-variant p-lg md:p-xl shadow-sm rounded">
  <div class="mb-lg border-b border-outline-variant pb-md flex items-center justify-between">
    <h2 class="font-headline-md text-headline-md text-on-surface">Service Ticket</h2>
    <span class="text-label-md font-label-md bg-surface-container-highest px-3 py-1 rounded text-on-surface-variant">SERIALIZED WORKFLOW</span>
  </div>
  <form class="space-y-lg">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
      <div class="flex flex-col gap-2">
        <label class="font-label-md text-label-md text-on-surface-variant uppercase">Owner Full Name</label>
        <input
          class="bg-surface-container-low border border-outline px-4 py-3 focus:border-primary focus:ring-0 transition-colors text-body-md rounded-none outline-none"
          placeholder="e.g. Julian Martinez" type="text" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="font-label-md text-label-md text-on-surface-variant uppercase">Contact Phone</label>
        <input
          class="bg-surface-container-low border border-outline px-4 py-3 focus:border-primary focus:ring-0 transition-colors text-body-md rounded-none outline-none"
          placeholder="+57 300 000 0000" type="tel" />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
      <div class="flex flex-col gap-2">
        <label class="font-label-md text-label-md text-on-surface-variant uppercase">Equipment Model</label>
        <select
          class="bg-surface-container-low border border-outline px-4 py-3 focus:border-primary focus:ring-0 transition-colors text-body-md rounded-none outline-none">
          <option>GoldFX Clipper</option>
          <option>SilverFX Trimmer</option>
          <option>RoseFX Dryer</option>
          <option>Lo-Pro FX Series</option>
          <option>Other BaByliss PRO</option>
        </select>
      </div>
      <div class="flex flex-col gap-2">
        <label class="font-label-md text-label-md text-on-surface-variant uppercase">Service Type</label>
        <select
          class="bg-surface-container-low border border-outline px-4 py-3 focus:border-primary focus:ring-0 transition-colors text-body-md rounded-none outline-none">
          <option>Blade Alignment</option>
          <option>Motor Replacement</option>
          <option>Battery Optimization</option>
          <option>General Cleaning & Calibration</option>
          <option>Warranty Claim</option>
        </select>
      </div>
    </div>
    <div class="flex flex-col gap-2">
      <label class="font-label-md text-label-md text-on-surface-variant uppercase">Issue Description</label>
      <textarea
        class="bg-surface-container-low border border-outline px-4 py-3 focus:border-primary focus:ring-0 transition-colors text-body-md rounded-none outline-none"
        placeholder="Describe the technical failure in detail..." rows="4"></textarea>
    </div>
    <div class="pt-md border-t border-outline-variant flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2">
        <input class="text-primary focus:ring-primary h-4 w-4 rounded-none border-outline" id="terms" type="checkbox" />
        <label class="text-body-md text-on-surface-variant text-sm" for="terms">I agree to the repair terms and conditions.</label>
      </div>
      <button
        class="w-full md:w-auto bg-primary text-white px-xl py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-primary-container transition-all active:scale-95"
        type="submit">Submit Registration</button>
    </div>
  </form>
</div>
