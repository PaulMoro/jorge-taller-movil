---
/**
 * SECCIÓN: Partner Banner
 * PROPÓSITO: Validación social mediante marcas aliadas.
 * CONTENIDO:
 *  - Texto: "Official Service Partner".
 *  - Imagen: Logo de BaByliss PRO.
 *  - Icono: Marca de verificado.
 *  - Texto: Ubicación (Bogotá · Colombia).
 */
import { SITE_CONFIG } from "../../config/site";
const { r2BaseUrl } = SITE_CONFIG;
---

<section class="bg-white border-y border-outline-variant py-12">
  <div class="container mx-auto px-8 max-w-7xl">
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-6 md:gap-10 text-center md:text-left"
    >
      <!-- Item 1: Label -->
      <span
        class="font-label-md text-on-surface-variant uppercase opacity-60 tracking-widest"
      >
        Liderazgo en Mantenimiento
      </span>

      <!-- Item 2: Brands/Logos -->
      <div
        class="flex flex-col md:flex-row items-center gap-8 md:gap-16 grayscale-0 opacity-100 md:grayscale md:opacity-80 md:hover:grayscale-0 md:hover:opacity-100 transition-all duration-500"
      >
        <img
          alt="BaByliss PRO Logo"
          class="h-16 w-auto object-contain"
          src={`${r2BaseUrl}/marketing/BaBylisspro.png`}
        />
        <img
          alt="Strong Machine Logo"
          class="h-16 w-auto object-contain"
          src={`${r2BaseUrl}/marketing/strong-machine.webp`}
        />
        <img
          alt="Wahl Logo"
          class="h-16 w-auto object-contain"
          src={`${r2BaseUrl}/marketing/wahl-logo.png`}
        />
      </div>

      <!-- Item 3: Location -->
      <span
        class="font-label-md text-on-surface-variant uppercase opacity-60 tracking-widest"
      >
        Bogotá · Colombia
      </span>
    </div>
  </div>
</section>
