---
/**
 * SECCIÓN: WhatsApp Community
 * PROPÓSITO: Conversión final y fidelización de la comunidad técnica.
 * CONTENIDO:
 *  - Títulos destacados (Comunidad Técnica).
 *  - Párrafo invitando al soporte prioritario.
 *  - Botón principal: "Unirme a la comunidad" (Link a WhatsApp).
 */
import { SOCIAL_LINKS } from "../../config/site";
---

<section class="py-xl border-t border-outline-variant bg-white">
  <div class="container mx-auto px-8 max-w-7xl text-center py-12">
    <div class="max-w-4xl mx-auto">
      <span
        class="font-label-md text-primary tracking-[0.2em] uppercase block mb-6 font-bold"
        >Comunidad Técnica</span
      >
      <h2 class="font-headline-md mb-8 uppercase tracking-tight">
        Recibe tips de mantenimiento y soporte prioritario
      </h2>
      <p class="text-body-lg text-on-surface-variant mb-10 font-medium">
        Únete a nuestra comunidad de WhatsApp para estar al tanto de las últimas
        tecnologías BaByliss PRO y asegurar el rendimiento óptimo de tus
        equipos.
      </p>

      <div class="flex justify-center">
        <a
          href={SOCIAL_LINKS.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-on-background text-surface px-12 py-5 font-label-md uppercase tracking-wider hover:bg-primary transition-all flex items-center gap-3 shadow-xl"
        >
          Unirme a la Comunidad <span class="material-symbols-outlined"
            >group</span
          >
        </a>
      </div>
    </div>
  </div>
</section>
