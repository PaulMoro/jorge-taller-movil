---
/**
 * SECCIÓN: Service Grid (Bento)
 * PROPÓSITO: Catálogo visual de especialidades técnicas.
 * CONTENIDO:
 *  - Grid asimétrico (Bento) con 3 servicios principales (Secadores, Planchas, Máquinas).
 *  - Sección destacada: Afilado Industrial con imagen de precisión.
 *  - Iconografía: Material Symbols (air, straighten, content_cut).
 *  - Botones: "Detalles" y "Conocer Proceso".
 */
import { SITE_CONFIG } from "../../config/site";
const { r2BaseUrl } = SITE_CONFIG;

const services = [
  {
    id: "secadores",
    title: "MANTENIMIENTO DE SECADORES",
    description:
      "Reparación y limpieza profunda. <br />¿Perdió potencia, hace ruidos extraños o ya no calienta?",
    icon: "air",
    bgIcon: "mode_fan",
    href: "/servicios",
    colSpan: "md:col-span-1",
    features: [
      "Diagnóstico técnico.",
      "Limpieza de cabello y químicos.",
      "Reparación de motor y escobillas.",
    ],
  },
  {
    id: "planchas",
    title: "AJUSTE DE PLANCHAS",
    description:
      "Reparación y control térmico. <br />¿No enciende, no calienta parejo o maltrata el cabello?",
    icon: "straighten",
    href: "/servicios",
    colSpan: "md:col-span-1",
    features: [
      "Diagnóstico y control térmico.",
      "Cambio de cables y tarjetas originales.",
      "Ajuste y alineación de placas.",
    ],
  },
  {
    id: "maquinas",
    title: "MÁQUINAS Y TIJERAS",
    description:
      "Afilado y puesta a punto. <br />¿Da tirones al cortar, se calienta rápido o vibra demasiado?",
    icon: "content_cut",
    href: "/servicios",
    colSpan: "md:col-span-1",
    features: [
      "Afilado de alta precisión.",
      "Calibración del motor y potencia.",
      "Alineación y ajuste de cuchillas.",
    ],
  },
];
---

<section class="py-xl bg-background">
  <div class="container mx-auto px-8 max-w-7xl py-8">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2
        class="font-headline-md text-on-background mb-4 uppercase tracking-tight"
      >
        Nuestro Servicio Técnico
      </h2>
      <p class="text-body-md text-on-surface-variant">
        Soluciones integrales diseñadas para prolongar la vida útil y optimizar
        el desempeño de cada herramienta en tu estación de trabajo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        services.map((service) => (
          <div
            class={`${service.colSpan} group bg-surface-container-low p-8 border border-outline-variant hover:border-primary transition-all relative overflow-hidden min-h-[400px] md:h-[400px] flex flex-col justify-start`}
          >
            <div class="absolute top-8 left-8">
              <span class="material-symbols-outlined text-4xl text-primary">
                {service.icon}
              </span>
            </div>

            <div class="relative z-10 pt-12 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="font-headline-sm mb-2">{service.title}</h3>
                <p
                  class="text-body-md text-on-surface-variant mb-4"
                  set:html={service.description}
                />

                {service.features && (
                  <ul class="text-label-md space-y-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                    {service.features.map((f) => (
                      <li class="flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-primary rounded-full" /> {f}
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              {service.href ? (
                <a
                  href={service.href}
                  class="text-primary font-label-md flex items-center gap-2 mt-4"
                >
                  DETALLES{" "}
                  <span class="material-symbols-outlined text-sm">add</span>
                </a>
              ) : null}
            </div>

            {service.bgIcon && (
              <div class="absolute right-[-20px] bottom-[-20px] opacity-10 group-hover:opacity-20 transition-all group-hover:scale-110 duration-500">
                <span class="material-symbols-outlined text-[180px]">
                  {service.bgIcon}
                </span>
              </div>
            )}
          </div>
        ))
      }

      <!-- Afilado Especializado (Full Width Row) -->
      <div
        class="md:col-span-3 bg-white border border-outline-variant p-8 md:p-12 flex flex-col md:flex-row items-center gap-12"
      >
        <div class="md:w-1/2 overflow-hidden">
          <img
            alt="Precision sharpening"
            class="w-full aspect-video md:aspect-square object-cover object-right transition-transform duration-700 hover:scale-105"
            src={`${r2BaseUrl}/marketing/jorge-rodriguez.png`}
          />
        </div>
        <div class="md:w-1/2">
          <span
            class="font-label-md text-primary tracking-widest uppercase mb-4 block font-bold"
            >TALLER MÓVIL A DOMICILIO</span
          >
          <h3 class="font-headline-md mb-6 leading-tight">
            Más de 30 años respaldando a los profesionales de la belleza
          </h3>
          <p class="text-body-lg text-on-surface-variant mb-8 font-medium">
            No pierdas tiempo y dinero llevando tus equipos a talleres
            desconocidos. Llegamos con nuestra unidad móvil directamente a tu
            peluquería en Bogotá y municipios aledaños. Trabajamos
            exclusivamente con repuestos originales y te damos garantía por
            escrito. Miles de estilistas y barberos ya nos conocen y confían en
            nosotros porque dejamos sus herramientas listas en su propia puerta,
            sin que tengan que parar de trabajar. El día no para y <span
              class="text-primary font-bold">Jorge Taller Móvil</span
            > está para ayudarte.
          </p>
          <a
            href="/contacto"
            class="inline-block bg-on-background text-surface px-8 py-4 font-label-md uppercase tracking-wider hover:bg-primary transition-all"
          >
            CONTACTAR
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
