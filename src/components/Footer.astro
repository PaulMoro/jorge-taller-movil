---
import { SOCIAL_LINKS, SITE_CONFIG } from "../config/site";
---

<footer class="bg-slate-50 border-t border-slate-200">
  <div
    class="max-w-7xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-4 gap-12"
  >
    <div class="col-span-1 md:col-span-1">
      <div
        class="text-lg font-bold text-slate-900 uppercase mb-j-md font-['Space_Grotesk']"
      >
        {SITE_CONFIG.name}
      </div>
      <p class="text-slate-500 font-['Space_Grotesk'] text-sm mb-j-md">
        Líderes en servicio técnico especializado para salones profesionales y barberías de alta gama.
      </p>
      <div class="flex gap-4">
        <a
          class="material-symbols-outlined text-slate-400 hover:text-primary transition-all"
          href="#">share</a
        >
        <a
          class="material-symbols-outlined text-slate-400 hover:text-primary transition-all"
          href={`mailto:${SITE_CONFIG.email}`}>mail</a
        >
        <a
          class="material-symbols-outlined text-slate-400 hover:text-primary transition-all"
          href={SOCIAL_LINKS.whatsapp}>call</a
        >
      </div>
    </div>
    <div>
      <h5 class="text-label-md font-label-md uppercase mb-j-lg">
        Políticas de servicio
      </h5>
      <ul class="space-y-j-sm">
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="#">Política de privacidad</a
          >
        </li>
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="#">Política de garantía</a
          >
        </li>
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="#">Garantía de servicio</a
          >
        </li>
        <!--<li>
          <a
            class="text-slate-900 font-semibold underline font-['Space_Grotesk'] text-sm"
            href="#">Repair Tracking</a
          >
        </li>-->
      </ul>
    </div>
    <div>
      <h5 class="text-label-md font-label-md uppercase mb-j-lg">
        Accesos Rapidos
      </h5>
      <ul class="space-y-j-sm">
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="/">Inicio</a
          >
        </li>
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="/servicios">Servicios</a
          >
        </li>
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="/catalogo">Catálogo</a
          >
        </li>
        <li>
          <a
            class="text-slate-500 hover:text-slate-800 transition-all font-['Space_Grotesk'] text-sm"
            href="/soporte">Soporte</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h5 class="text-label-md font-label-md uppercase mb-j-lg">
        Horario de Atención
      </h5>
      <p class="text-slate-500 font-['Space_Grotesk'] text-sm">
        {SITE_CONFIG.address}<br />
        Bogotá, Colombia
      </p>
      <p class="text-slate-500 font-['Space_Grotesk'] text-sm">
        Lunes - Viernes: 8am - 6pm<br />
        Sábados: 9am - 1pm<br />
        Domingos: Cerrado
      </p>
    </div>
  </div>
  <div class="border-t border-slate-200 py-8 px-8">
    <div
      class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-j-sm"
    >
      <div class="text-center md:text-left">
        <p
          class="text-slate-500 font-['Space_Grotesk'] text-xs uppercase tracking-widest"
        >
          © {new Date().getFullYear()}
          {SITE_CONFIG.name}. Excelencia Técnica en Herramientas de Estilismo. Bogotá, Colombia. Distribuidor Oficial de BaByliss PRO.
        </p>
      </div>
      <div class="flex gap-j-sm mt-4 md:mt-0">
        <img
          alt="Visa"
          class="h-6 opacity-50"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBSif7FgeoSlzcsTH1Fb9EY7dUDk6e9HFILGHkE7HTL4DZsW4SJFAPSfNSId6KgkgxdQNJZQLPOBGTbYOU0kkO1H_10GrIByWphaAlNGo5LjtMQJL9CPbgQZgSjVzoIJtKpFP3qJ1rxWkhsOS73MRWxCAfffqtoyYNhnxiuOSHucYu2EmJlO6myHaS0cfJy-6ydwiNSlcNpskT731FMK_EzCUS8CqYBbiPz6_taGm0_zLUpb9O22fJKYL7hQ7GKxZk2XH0KFCLxoGTg"
        />
        <img
          alt="Mastercard"
          class="h-6 opacity-50"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBzkfGefO59lVjRHpLaVz48yui-Nw8KLi04utiBr9V21xflhcAFqCIEeLjBtDgbRbr5W9Sl_3kHYYBCdLoK0JG2kuFI7xs5FFzkm1vmTNFrxXDwfvf2J1GylWpimCeVfOM-7d2lK8A6tETImFzHTL0jbeu2WkSadalzbvhShDUcBRlk9ViQhquD2gcqFZ4yCJOR3JXZHEC0HwNTZUt_HPbsCN9eL-KlWXRCxGXxinoTF7JICguN7JPdErF_QXlQ-pr3QbK2ZUrGYrcR"
        />
      </div>
    </div>
  </div>

  <!-- Yordana Saladen Marketing Section (Trigger Banner) -->
  <div class="bg-rose-50 py-4 px-4 text-center border-t border-rose-100">
    <p class="text-rose-900 font-['Space_Grotesk'] text-sm md:text-base uppercase tracking-widest font-medium">
      Estrategia de marketing por <button id="yordana-toggle" class="text-rose-500 underline hover:text-rose-700 transition-all font-bold">Yordana Saladen</button>
    </p>
  </div>

  <!-- Yordana Saladen Marketing Section (Bottom Banner) -->
  <div id="yordana-section" class="fixed bottom-0 left-0 w-full z-[100] bg-rose-50 text-rose-900 shadow-[0_-20px_50px_rgba(0,0,0,0.1)] overflow-y-auto max-h-[95vh] border-t border-rose-200 transform translate-y-full transition-transform duration-500 ease-in-out">
    <button id="yordana-close" class="absolute top-4 right-4 md:top-6 md:right-6 text-rose-400 hover:text-rose-800 transition-colors p-2 rounded-full hover:bg-rose-100 flex items-center justify-center cursor-pointer">
      <span class="material-symbols-outlined">close</span>
    </button>
    <div class="max-w-7xl mx-auto px-8 py-10 md:py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-2xl md:text-3xl font-bold text-rose-950 mb-4 font-['Space_Grotesk']">
            Estrategia de Marketing Integral
          </h3>
          <p class="text-rose-800 mb-6 leading-relaxed">
            Este proyecto web es una pieza fundamental dentro de una estrategia de marketing 360° diseñada y ejecutada por <strong>Yordana Saladen</strong>. El objetivo principal es consolidar la presencia digital de Jorge Rodríguez, destacando su expertise técnico de más de 30 años en el mercado.
          </p>
          <div class="space-y-4">
            <h4 class="font-bold text-rose-950 uppercase text-sm tracking-wider">Habilidades Clave:</h4>
            <ul class="space-y-2">
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-rose-500">campaign</span>
                <span class="text-rose-700">Dirección de Marketing Digital</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-rose-500">insights</span>
                <span class="text-rose-700">Análisis y Estrategia de Crecimiento</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-rose-500">visibility</span>
                <span class="text-rose-700">Posicionamiento de Marca (Branding)</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-rose-500">web</span>
                <span class="text-rose-700">Estrategia Web y UX/UI</span>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-rose-200 text-rose-900 rounded-lg hover:bg-rose-300 transition-colors font-medium">
              Contactar a Yordana
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="flex justify-center md:justify-end">
          <div class="relative w-56 h-56 md:w-72 md:h-72 rounded-2xl overflow-hidden shadow-xl ring-4 ring-rose-100">
            <img src="/yordi_saladen.png" alt="Yordana Saladen - Estratega de Marketing" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-rose-900/40 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 text-white">
              <p class="font-bold text-lg drop-shadow-md">Yordana Saladen</p>
              <p class="text-sm opacity-90 text-rose-50 drop-shadow-md">Marketing Strategist</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('yordana-toggle');
    const yordanaSection = document.getElementById('yordana-section');
    const closeBtn = document.getElementById('yordana-close');
    
    if (toggleBtn && yordanaSection) {
      toggleBtn.addEventListener('click', (e) => {
        e.preventDefault();
        yordanaSection.classList.toggle('translate-y-full');
      });
    }

    if (closeBtn && yordanaSection) {
      closeBtn.addEventListener('click', () => {
        yordanaSection.classList.add('translate-y-full');
      });
    }
  });
</script>
