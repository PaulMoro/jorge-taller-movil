---
/**
 * Resumen: Barra lateral con información de contacto y disponibilidad.
 * Contenido: Disponibilidad en tiempo real, horarios de atención, ubicación con mapa y redes sociales.
 * Interacción: Alineado a paleta oficial (Material Design 3), hover interactivo en enlaces y mapa.
 */
import { SOCIAL_LINKS, SITE_CONFIG } from '../../config/site';
---
<aside class="lg:col-span-4 space-y-j-lg">
  
  <!-- Status & Availability -->
  <div class="bg-surface-container-lowest border border-outline-variant p-j-lg rounded shadow-sm">
    <h3 class="font-headline-sm text-headline-sm text-on-surface mb-j-md">Disponibilidad en Tiempo Real</h3>
    <div class="space-y-j-sm">
      <div class="flex items-center justify-between border-b border-outline-variant pb-j-xs">
        <div class="flex items-center gap-3">
          <div class="bg-primary-container/20 p-2 rounded flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[20px]">engineering</span>
          </div>
          <span class="text-body-md font-medium text-on-surface">Técnicos en Línea</span>
        </div>
        <span class="font-label-md text-label-md px-2 py-1 bg-green-100 text-green-800 rounded">6 ACTIVOS</span>
      </div>
      <div class="flex items-center justify-between border-b border-outline-variant pb-j-xs">
        <div class="flex items-center gap-3">
          <div class="bg-primary-container/20 p-2 rounded flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[20px]">schedule</span>
          </div>
          <span class="text-body-md font-medium text-on-surface">Tiempo de Espera</span>
        </div>
        <span class="text-body-md text-on-surface-variant">~45 min</span>
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="bg-primary-container/20 p-2 rounded flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[20px]">event_available</span>
          </div>
          <span class="text-body-md font-medium text-on-surface">Próximo Turno</span>
        </div>
        <span class="text-body-md text-on-surface-variant">Hoy, 2:30 PM</span>
      </div>
    </div>
  </div>

  <!-- Business Hours Card -->
  <div class="bg-tertiary-fixed text-on-tertiary-fixed p-j-lg border border-outline-variant rounded">
    <h3 class="font-headline-sm text-headline-sm mb-j-md flex items-center gap-2">
      <span class="material-symbols-outlined">storefront</span>
      Horarios de Atención
    </h3>
    <ul class="space-y-j-xs text-body-md">
      <li class="flex justify-between border-b border-on-tertiary-fixed/10 pb-2">
        <span>Lunes - Viernes</span> 
        <span>08:00 - 18:00</span>
      </li>
      <li class="flex justify-between border-b border-on-tertiary-fixed/10 pb-2">
        <span>Sábado</span> 
        <span>09:00 - 14:00</span>
      </li>
      <li class="flex justify-between font-bold text-primary pt-1">
        <span>Domingo</span> 
        <span>CERRADO</span>
      </li>
    </ul>
  </div>

  <!-- Location Canvas -->
  <div class="bg-surface-container-highest border border-outline-variant overflow-hidden rounded">
    <div class="h-48 relative overflow-hidden group cursor-pointer">
      <img alt="Location Map"
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 ease-out"
        src="https://lh3.googleusercontent.com/aida/ADBb0ug26pimlYuVWW2uo-YQjPrhV5BqDljrMXNK7Zrv08gVvLuFGiHmbuyzw1VpnVs-M9l1j8rbHLOeMMC6thsFSmOWTzAVfwq_2qg5Dn87qIRhMGTFw8XUA6h47fyiYPvjlP5-WgTtTgO0MkzaQBe2S3Ex62B7niad1eOkffxMwbb85SnQfG3pmxo3WY5S3W4YqaNwKDHYqdzFk4kW_vf8sXMy8LX4rZHctnket40zUP2RAnACU5oP3UNIRC0eRydTXeWg1yJmYNbta10" />
      <div class="absolute inset-0 bg-primary/10 flex items-center justify-center pointer-events-none group-hover:bg-transparent transition-colors">
        <span class="material-symbols-outlined text-on-primary text-5xl drop-shadow-md group-hover:-translate-y-1 transition-transform" style="font-variation-settings: 'FILL' 1;">location_on</span>
      </div>
    </div>
    <div class="p-j-md bg-surface-container-lowest border-t border-outline-variant">
      <p class="font-label-md text-label-md text-on-surface uppercase mb-1">Sede Principal</p>
      <p class="text-body-md text-on-surface-variant">{SITE_CONFIG.address}</p>
      <div class="mt-j-sm flex gap-4">
        <a class="text-primary flex items-center gap-2 hover:underline hover:text-primary-container transition-colors font-label-md text-label-md" href="#">
          <span class="material-symbols-outlined text-sm">directions</span> CÓMO LLEGAR
        </a>
      </div>
    </div>
  </div>

  <!-- Social & Contact -->
  <div class="flex justify-between items-center p-j-md border border-outline-variant rounded bg-surface-container-lowest shadow-sm">
    <div class="flex gap-4">
      <a class="material-symbols-outlined text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10" href={SOCIAL_LINKS.whatsapp} target="_blank">phone_in_talk</a>
      <a class="material-symbols-outlined text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10" href={`mailto:contacto@jorgerodriguez.com`}>mail</a>
    </div>
    <div class="flex gap-2 flex-wrap justify-end">
      {SOCIAL_LINKS.instagram && (
        <a class="text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10 flex items-center justify-center" target="_blank" href={SOCIAL_LINKS.instagram} aria-label="Instagram">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      )}
      {SOCIAL_LINKS.facebook && (
        <a class="text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10 flex items-center justify-center" target="_blank" href={SOCIAL_LINKS.facebook} aria-label="Facebook">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      )}
      {SOCIAL_LINKS.Tiktok && (
        <a class="text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10 flex items-center justify-center" target="_blank" href={SOCIAL_LINKS.Tiktok} aria-label="TikTok">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
      )}
      {SOCIAL_LINKS.linkedin && (
        <a class="text-on-surface hover:text-primary transition-colors p-2 rounded hover:bg-primary-container/10 flex items-center justify-center" target="_blank" href={SOCIAL_LINKS.linkedin} aria-label="LinkedIn">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      )}
    </div>
  </div>
</aside>
